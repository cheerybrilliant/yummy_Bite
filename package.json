{
  "name": "yummy-bite",
  "version": "1.0.0",
  "description": "ICT University canteen management system",
  "main": "backend/dist/index.js",
  "scripts": {
    "start": "node backend/dist/index.js",
    "build": "prisma generate",
    "dev": "nodemon backend/dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node prisma/seed.js",
    "setup": "npm run db:generate && npm run db:push && npm run db:seed",
    "render-build": "npm run db:generate"
  },
  "prisma": {
    "seed": "node prisma/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.2"
  },
  "devDependencies": {
    "nodemon": "^3.1.10",
    "prisma": "^5.22.0"
  }
}
