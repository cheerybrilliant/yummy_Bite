generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(STUDENT)
  phone     String
  createdAt DateTime @default(now())

  orders  Order[]
  reviews Review[]
  votes   Vote[]
}

enum Role {
  STUDENT
  STAFF
  ADMIN
}

model Dish {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float
  category    Category
  image       String
  createdAt   DateTime @default(now())

  dailyMenus DailyMenu[]
  orderItems OrderItem[]
  reviews    Review[]
  votes      Vote[]
}

enum Category {
  BREAKFAST
  LUNCH
  SNACK
}

model DailyMenu {
  id       String   @id @default(uuid())
  date     DateTime @default(now())
  quantity Int
  isActive Boolean  @default(true)
  dishId   String
  dish     Dish     @relation(fields: [dishId], references: [id])
}

model Order {
  id          String      @id @default(uuid())
  totalAmount Float
  status      OrderStatus @default(PENDING_PAYMENT)
  createdAt   DateTime    @default(now())
  studentId   String
  student     User        @relation(fields: [studentId], references: [id])

  items   OrderItem[]
  payment Payment?
  receipt Receipt?
  reviews Review[]
}

enum OrderStatus {
  PENDING_PAYMENT
  AWAITING_VERIFICATION
  PAYMENT_CONFIRMED
  PREPARING
  READY_FOR_COLLECTION
  COMPLETED
  ABANDONED
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float
  orderId  String
  dishId   String
  order    Order  @relation(fields: [orderId], references: [id])
  dish     Dish   @relation(fields: [dishId], references: [id])
}

model Payment {
  id             String        @id @default(uuid())
  screenshot     String
  transactionId  String
  status         PaymentStatus @default(PENDING)
  rejectedReason String?
  createdAt      DateTime      @default(now())
  orderId        String        @unique
  order          Order         @relation(fields: [orderId], references: [id])
}

enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Receipt {
  id          String   @id @default(uuid())
  collectedAt DateTime @default(now())
  orderId     String   @unique
  order       Order    @relation(fields: [orderId], references: [id])
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  studentId String
  orderId   String   @unique
  dishId    String
  student   User     @relation(fields: [studentId], references: [id])
  order     Order    @relation(fields: [orderId], references: [id])
  dish      Dish     @relation(fields: [dishId], references: [id])
}

model Vote {
  id        String   @id @default(uuid())
  count     Int      @default(1)
  week      String
  createdAt DateTime @default(now())
  studentId String
  dishId    String
  student   User     @relation(fields: [studentId], references: [id])
  dish      Dish     @relation(fields: [dishId], references: [id])
}

model Ballot {
  id        String   @id @default(uuid())
  week      String   @unique
  isOpen    Boolean  @default(true)
  createdAt DateTime @default(now())
}
